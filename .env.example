# PostgreSQL connection string.
# For Supabase: copy the Connection string → URI from Project Settings → Database.
# For local dev: run `docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16`
# and use: postgresql://postgres:postgres@localhost:5432/mytools
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mytools"

# NextAuth secret used to sign the session JWT. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-32-byte-random-string"

# Absolute URL where the app is hosted. Use http://localhost:3000 for dev.
NEXTAUTH_URL="http://localhost:3000"

# 32-byte base64 key used (Sprint 3+) for AES-256-GCM encryption of user contact info.
# Generate with:
#   openssl rand -base64 32
CONTACT_ENCRYPTION_KEY="replace-with-32-byte-base64-key"

# Google Maps Geocoding API key used to convert admin-entered addresses
# into approximate coordinates for directory maps. Keep this secret.
GOOGLE_MAPS_API_KEY="replace-with-your-google-maps-api-key"

# Optional: seed the first admin user with custom credentials when running `npm run seed`.
# If omitted, defaults are admin@mytools.rw / ChangeMeNow!2026.
SEED_ADMIN_EMAIL="admin@mytools.rw"
SEED_ADMIN_PASSWORD="ChangeMeNow!2026"
